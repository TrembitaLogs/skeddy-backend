# Database
DATABASE_URL=postgresql+asyncpg://skeddy:password@localhost:5432/skeddy
DB_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@skeddy.app
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Skeddy <noreply@skeddy.app>

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_CREDENTIALS_JSON=

# Google Play Billing
GOOGLE_PLAY_CREDENTIALS_PATH=
GOOGLE_PLAY_CREDENTIALS_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.skeddy.driver

# Sentry
SENTRY_DSN=

# App Settings
DEFAULT_SEARCH_INTERVAL_SECONDS=30
MIN_SEARCH_APP_VERSION=1.0.0
SEARCH_APP_UPDATE_URL=https://skeddy-search-releases.sfo3.cdn.digitaloceanspaces.com/search/skeddy-search-latest.apk

# Health Monitor
HEALTH_CHECK_INTERVAL_MINUTES=5
OFFLINE_NOTIFICATION_THRESHOLD_MINUTES=30

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SECRET_KEY=your-random-secret-key-for-sessions

# Certbot / Let's Encrypt
CERTBOT_EMAIL=admin@skeddy.net

# Backup (optional S3/Spaces upload)
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=backups
BACKUP_S3_ENDPOINT=https://sfo3.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
